{
  "name": "fullstack_basic",
  "domain": "${subdomain}.fixture.test",
  "components": {
    "db": {
      "uses": "sqlite"
    },
    "postgres": {
      "mode": "managed",
      "command": "postgres -D ${dataRoot}/postgres -h 127.0.0.1 -p ${postgres.port}",
      "health": "pg_isready -h 127.0.0.1 -p ${postgres.port}",
      "readyTimeout": 60
    },
    "convex": {
      "uses": "convex",
      "dependsOn": ["postgres"]
    },
    "api": {
      "mode": "managed",
      "command": "bun run api -- --host 127.0.0.1 --port ${api.port} --sqlite ${db.path}",
      "health": "http://127.0.0.1:${api.port}/health",
      "dependsOn": ["db", "postgres", "convex"]
    },
    "web": {
      "mode": "managed",
      "command": "bunx vite preview --host 127.0.0.1 --port ${web.port}",
      "health": "http://127.0.0.1:${web.port}",
      "dependsOn": ["api"]
    }
  },
  "local": {
    "proxy": {
      "upstream": "web"
    },
    "components": {
      "postgres": {
        "port": 55432
      },
      "convex": {
        "port": 3210,
        "sitePort": 3211
      },
      "api": {
        "command": "bun --watch run api -- --host 127.0.0.1 --port ${api.port} --sqlite ${db.path}",
        "port": 8081
      },
      "web": {
        "command": "bunx vite --host 127.0.0.1 --port ${web.port}",
        "port": 5173
      }
    }
  },
  "live": {
    "proxy": {
      "upstream": "web"
    },
    "components": {
      "postgres": {
        "port": 55433
      },
      "convex": {
        "port": 3220,
        "sitePort": 3221
      },
      "api": {
        "port": 8080
      },
      "web": {
        "port": 3070
      }
    }
  },
  "deployments": {
    "subdomain": "${branchSlug}",
    "providerProfile": "stub",
    "proxy": {
      "upstream": "web"
    }
  }
}
