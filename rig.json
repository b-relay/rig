{
  "name": "rig",
  "version": "0.2.0",
  "hooks": {
    "preStart": "bun install"
  },
  "environments": {
    "prod": {
      "gitBranch": "main",
      "services": [
        {
          "name": "rig",
          "type": "bin",
          "entrypoint": "rig",
          "build": "bun build --compile src/index.ts --outfile rig"
        }
      ]
    }
  }
}
